          "name": "Unnamed credential 2"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Build cluster_summaries map and prepare API request\nconst opensearchResponse = $input.item.json;\nconst categoryData = $('Group Clusters by Category').item.json;\n\nconst clusterSummaries = {};\nlet foundCount = 0;\n\nif (opensearchResponse.hits && opensearchResponse.hits.hits && opensearchResponse.hits.hits.length > 0) {\n  opensearchResponse.hits.hits.forEach(hit => {\n    const source = hit._source;\n    if (source.cluster_id && source.summary) {\n      clusterSummaries[source.cluster_id] = source.summary;\n      foundCount++;\n    }\n  });\n}\n\nconst requestId = `mega_${categoryData.category_name}_${Date.now()}`;\n\nconsole.log('='.repeat(60));\nconsole.log(`📋 PREPARING MEGA SUMMARY REQUEST`);\nconsole.log('='.repeat(60));\nconsole.log(`Category: ${categoryData.category_name}`);\nconsole.log(`Request ID: ${requestId}`);\nconsole.log(`Clusters requested: ${categoryData.cluster_ids.length}`);\nconsole.log(`Summaries found: ${foundCount}`);\nconsole.log(`Missing summaries: ${categoryData.cluster_ids.length - foundCount}`);\nconsole.log('='.repeat(60));\n\nif (foundCount === 0) {\n  console.warn(`⚠️ No summaries found for category \"${categoryData.category_name}\" - skipping`);\n  return {\n    json: {\n      skip: true,\n      category_name: categoryData.category_name,\n      reason: 'no_summaries_found'\n    }\n  };\n}\n\n// Return payload for API\nreturn {\n  json: {\n    request_id: requestId,\n    category_name: categoryData.category_name,\n    cluster_ids: categoryData.cluster_ids,\n    cluster_summaries: clusterSummaries\n  }\n};"
      },
