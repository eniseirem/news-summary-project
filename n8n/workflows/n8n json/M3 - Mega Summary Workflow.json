        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": {\n    \"terms\": {\n      \"cluster_id\": {{ JSON.stringify($json.cluster_ids) }}\n    }\n  },\n  \"_source\": [\"cluster_id\", \"summary\"],\n  \"size\": {{ $json.cluster_ids.length }}\n}",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "4bc133f7-c1d7-4799-b41c-923db1a85581",
      "name": "Get Cluster Summaries for Category",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        16,
        480
      ],
      "credentials": {
        "httpBasicAuth": {
