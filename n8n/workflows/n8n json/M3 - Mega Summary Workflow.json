      "parameters": {
        "method": "POST",
        "url": "=https://opensearch:9200/clusters/_search",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        {\n          \"exists\": {\n            \"field\": \"category\"\n          }\n        }\n      ]\n    }\n  },\n  \"_source\": [\"cluster_id\", \"category\", \"article_count\"],\n  \"size\": 10000\n}",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "7c5c5244-9afd-40dd-a123-95fb8a2ebd1a",
      "name": "Get Clusters with Category",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -464,
        480
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "Trv8tso5MyKF1SQR",
          "name": "Unnamed credential 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Group clusters by category\nconst input = $input.item.json;\n\nif (!input.hits || !input.hits.hits || input.hits.hits.length === 0) {\n  console.log('⚠️ No clusters found with categories');\n  return [];\n}\n\nconst clustersByCategory = {};\n\ninput.hits.hits.forEach(hit => {\n  const source = hit._source;\n  const category = source.category;\n  const clusterId = source.cluster_id;\n  \n  if (!category || !clusterId) {\n    return; // Skip invalid entries\n  }\n  \n  if (!clustersByCategory[category]) {\n    clustersByCategory[category] = {\n      category_name: category,\n      cluster_ids: [],\n      cluster_count: 0\n    };\n  }\n  \n  clustersByCategory[category].cluster_ids.push(clusterId);\n  clustersByCategory[category].cluster_count++;\n});\n\n// Convert to array\nconst categories = Object.values(clustersByCategory);\n\nconsole.log('='.repeat(60));\nconsole.log('📊 CLUSTERS GROUPED BY CATEGORY');\nconsole.log('='.repeat(60));\ncategories.forEach(cat => {\n  console.log(`${cat.category_name}: ${cat.cluster_count} clusters`);\n});\nconsole.log('='.repeat(60));\nconsole.log(`Total categories: ${categories.length}`);\nconsole.log(`Total clusters: ${input.hits.total.value}`);\nconsole.log('='.repeat(60));\n\nif (categories.length === 0) {\n  console.log('⚠️ No valid categories found');\n  return [];\n}\n\n// Return array - n8n will create separate items for each category\nreturn categories;"
      },
      "id": "beff7372-7df5-4c3e-9b6a-3bc458f3d172",
      "name": "Group Clusters by Category",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
