    {
      "parameters": {
        "jsCode": "// Prepare Error Log for Crawler API\n// When error occurs, the input is the error object and source data is in the same item\nconst inputData = $input.first().json;\n\n// Extract source info - it's in the same object when error occurs\nconst sourceInfo = {\n  id: inputData.id || 'unknown',\n  name: inputData.name || 'unknown',\n  endpoint: inputData.endpoint || 'unknown',\n  run_id: inputData.run_id || Date.now()\n};\n\nconst error = inputData.error || {};\n\nconst logData = {\n  request_id: sourceInfo.run_id + '-' + sourceInfo.id + '-error',\n  source: 'news_crawler',\n  endpoint: '/crawl/' + sourceInfo.id,\n  http_method: 'GET',\n  status: 'failed',\n  http_code: error.status || 500,\n  created_at: new Date().toISOString(),\n  error_type: error.code || error.name || 'API_ERROR',\n  error_message: error.message || String(error),\n  attempt: 1,\n  triggered_by: 'n8n',\n  payload_excerpt: {\n    source_id: sourceInfo.id,\n    source_name: sourceInfo.name,\n    endpoint: sourceInfo.endpoint\n  }\n};\n\nreturn [{\n  json: {\n    log_data: logData,\n    error: error,\n    source_info: sourceInfo\n  }\n}];"
