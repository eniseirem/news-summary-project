    {
      "parameters": {
        "jsCode": "// Prepare Article Log - FOR OPENSEARCH\nconst response = $json;\nconst article = $input.item.json || $json;\n\nconst source = article.crawler_source || 'unknown';\nconst articleId = (article.id || 'no-id').substring(0, 80);\n\nconst logData = {\n  request_id: article.run_id + '-' + articleId.substring(0, 20),\n  source: 'news_crawler',\n  endpoint: '/crawl/' + source,\n  http_method: 'GET',\n  status: response.error ? 'failed' : 'success',\n  http_code: response.error ? 500 : 200,\n  created_at: new Date().toISOString(),\n  error_type: response.error ? 'INDEX_ERROR' : null,\n  error_message: response.error ? String(response.error) : null,\n  triggered_by: 'n8n',\n  payload_excerpt: {\n    article_id: articleId,\n    source: source,\n    title: (article.title || '').substring(0, 100)\n  }\n};\n\nreturn [{\n  json: {\n    ...response,\n    original_article: article,\n    log_data: logData\n  }\n}];"
      },
