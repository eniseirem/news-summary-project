      "parameters": {
        "jsCode": "// Prepare Summary Log - FOR OPENSEARCH\nconst summary = $('Create Summary1').first().json;\n\nconst logData = {\n  request_id: summary.run_id + '-summary',\n  source: 'news_crawler',\n  endpoint: '/crawl/summary',\n  http_method: 'POST',\n  status: summary.failed > 0 ? 'partial_success' : 'success',\n  http_code: 200,\n  created_at: summary.completed_at,\n  triggered_by: 'n8n',\n  payload_excerpt: {\n    total_sources: summary.total_sources,\n    total_articles: summary.total_articles,\n    successful: summary.successful,\n    failed: summary.failed,\n    by_source: summary.by_source\n  }\n};\n\nreturn [{\n  json: {\n    ...summary,\n    log_data: logData\n  }\n}];"
