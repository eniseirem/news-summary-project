    {
      "parameters": {
        "jsCode": "// Define all news sources (only functional endpoints)\nconst sources = [\n  // English sources\n  { name: 'CNN', id: 'cnn', endpoint: 'cnn', language: 'en' },\n  { name: 'ESPN', id: 'espn', endpoint: 'espn', language: 'en' },\n  { name: 'Fox News', id: 'foxnews', endpoint: 'foxnews', language: 'en' },\n  { name: 'Goal', id: 'goal', endpoint: 'goal', language: 'en' },\n  { name: 'Guardian', id: 'guardian', endpoint: 'guardian', language: 'en' },\n  { name: 'Guardian Sport', id: 'guardiansport', endpoint: 'guardiansport', language: 'en' },\n  { name: 'Japan Times', id: 'japantimes', endpoint: 'japantimes', language: 'en' },\n  { name: 'NBC', id: 'nbc', endpoint: 'nbc', language: 'en' },\n  { name: 'SBS', id: 'sbs', endpoint: 'sbs', language: 'en' },\n  { name: 'SCMP Economics', id: 'scmp_economics', endpoint: 'southchinamorningpost/economics', language: 'en' },\n  { name: 'SCMP Politics', id: 'scmp_politics', endpoint: 'southchinamorningpost/politics', language: 'en' },\n  { name: 'Tass', id: 'tass', endpoint: 'tass', language: 'en' },\n  { name: 'TeleSur', id: 'telesur', endpoint: 'telesur', language: 'en' },\n  { name: 'The News', id: 'thenews', endpoint: 'thenews', language: 'en' },\n  { name: 'Times of India', id: 'timesofindia', endpoint: 'timesofindia', language: 'en' },\n  { name: 'Yahoo Finance', id: 'yahoofinance', endpoint: 'yahoofinance', language: 'en' },\n  { name: 'Yahoo News', id: 'yahoonews', endpoint: 'yahoonews', language: 'en' },\n  \n  // German sources\n  { name: 'Bild', id: 'bild', endpoint: 'bild', language: 'de' },\n  { name: 'FAZ', id: 'faz', endpoint: 'faz', language: 'de' },\n  { name: 'Focus', id: 'focus', endpoint: 'focus', language: 'de' },\n  { name: 'NTV', id: 'ntv', endpoint: 'ntv', language: 'de' },\n  { name: 'Spiegel', id: 'spiegel', endpoint: 'spiegel', language: 'de' },\n  { name: 'Stern', id: 'stern', endpoint: 'stern', language: 'de' },\n  { name: 'Tagesspiegel', id: 'tagesspiegel', endpoint: 'tagesspiegel', language: 'de' },\n  { name: 'Welt', id: 'welt', endpoint: 'welt', language: 'de' },\n  \n  // Other\n  { name: 'RSS Feeds', id: 'rss', endpoint: 'rss', language: 'multi' }\n];\n\nconst runId = Date.now();\nreturn sources.map(source => ({\n  json: {\n    ...source,\n    run_id: runId,\n    started_at: new Date().toISOString()\n  },\n  pairedItem: { item: 0 }\n}));"
      },
      "id": "ad8dec67-8fb9-4264-ac15-5fc0a58563c8",
      "name": "Define All Sources",
