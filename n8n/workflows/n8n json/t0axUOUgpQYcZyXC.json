        1968,
        1216
      ]
    },
    {
      "parameters": {
        "jsCode": "// Get the cluster data that was just saved\nconst clusterData = $('Attach Summaries to Clusters').first().json;\n\nconst topicLabelPayload = {\n  request_id: `label_${clusterData.cluster_id}_${Date.now()}`,\n  summary: clusterData.summary,\n  cluster_id: clusterData.cluster_id\n};\n\nconsole.log(`🏷️ Returning topic_label payload for cluster ${clusterData.cluster_id}`);\n\nreturn [{ json: topicLabelPayload }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
