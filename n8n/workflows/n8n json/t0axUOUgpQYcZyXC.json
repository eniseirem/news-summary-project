      "parameters": {
        "jsCode": "// Format the LLM response for OpenSearch insert\nconst llmResponse = $input.first().json;\nconst cluster = llmResponse.clusters[0]; // Single cluster\n\nreturn {\n  cluster_id: cluster.cluster_id,\n  request_id: llmResponse.request_id,\n  article_ids: cluster.article_ids,\n  article_count: cluster.article_count,\n  summary: cluster.summary,\n  ingested_at: new Date().toISOString(),\n  processed_at: llmResponse.processed_at\n};"
      },
      "id": "25ad08fe-97e7-45ff-831b-47264b3112b2",
      "name": "Attach Summaries to Clusters",
