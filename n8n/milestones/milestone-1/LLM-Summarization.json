    {
      "parameters": {
        "jsCode": "const binaryData = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst articles = JSON.parse(binaryData.toString());\n\nconst shortArticles = articles.filter(a => a.body && a.body.length < 4000);\n\nconsole.log('📊 Total:', articles.length, 'Filtered:', shortArticles.length);\nconsole.log('🔄 Processing ONE BY ONE (model safety)');\n\nreturn shortArticles.map(article => ({json: article}));"
      },
