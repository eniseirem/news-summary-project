    {
      "parameters": {
        "jsCode": "const response = $json;\nconst inputItem = $('Split One by One').item.json;\n\nif (!response.final_summary || response.error || response.statusCode >= 400) {\n  // Error\n  const errorData = {\n    type: 'error',\n    article_id: inputItem.id,\n    title: inputItem.title,\n    source: inputItem.source,\n    error_message: response.message || response.error || JSON.stringify(response),\n    failed_at: new Date().toISOString()\n  };\n  console.error('❌ FAILED:', errorData.article_id);\n  return [{json: errorData}];\n}\n\n// Success\nconst successData = {\n  type: 'success',\n  article_id: inputItem.id,\n  title: inputItem.title,\n  source: inputItem.source,\n  url: inputItem.url,\n  summary: response.final_summary,\n  model: response.model,\n  processed_at: response.processed_at\n};\n\nconsole.log('✅ SUCCESS:', successData.article_id, '-', successData.title);\n\nconst jsonText = JSON.stringify(successData, null, 2);\n\nreturn [{\n  json: successData,\n  binary: {\n    data: {\n      data: Buffer.from(jsonText).toString('base64'),\n      mimeType: 'application/json',\n      fileName: `success_${successData.article_id}.json`\n    }\n  }\n}];"
      },
      "id": "a88c0e08-db01-4be9-abd4-4f7103be7aad",
      "name": "Process Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
