      "rouge_l": { "type": "float" },
      "bert_f1": { "type": "float" },
      "bleu": { "type": "float" },
      "language": { "type": "keyword" },
      "evaluated_at": { "type": "date" },
      "human_relevance": { "type": "integer" },
      "human_fluency": { "type": "integer" },
      "human_comments": { "type": "text", "analyzer": "en_analyzer" }
    }
  }
}